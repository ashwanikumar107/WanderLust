<% layout("/layouts/boilerplate") %>

<style>
    .full-width {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background-color: #f8f9fa;
        padding: 40px 60px;
    }

    .trending-title {
        text-align: center;
        margin-bottom: 40px;
        font-size: 2rem;
        font-weight: bold;
    }

    .trending-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    @media (max-width: 992px) {
        .trending-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .trending-container {
            grid-template-columns: 1fr;
        }
        .full-width {
            padding: 20px;
        }
    }

    .trending-card {
        background: white;
        border-radius: 12px;
        overflow: hidden; /* Keeps the zoomed image inside the card corners */
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .trending-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    /* --- New Image Hover Styling --- */
    .card-img-container {
        width: 100%;
        height: 250px;
        overflow: hidden; /* Clips the image when it scales */
    }

    .trending-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease; /* Smooth zoom transition */
    }

    .trending-card:hover img {
        transform: scale(1.1); /* Zooms the image in slightly */
    }
    /* ------------------------------ */

    .card-content {
        padding: 18px;
        flex-grow: 1;
    }

    .location {
        font-size: 18px;
        font-weight: bold;
    }

    .price {
        color: #28a745;
        font-weight: bold;
        margin-top: 6px;
    }

    .rating {
        color: #ff9800;
        margin-top: 6px;
    }

    .description {
        font-size: 14px;
        color: #555;
        margin-top: 8px;
    }
</style>

<div class="full-width">

    <h1 class="trending-title">
        <i class="fa-solid fa-fire"></i> Rooms in India
    </h1>

    <div class="trending-container">

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1626621341517-bbf3d9990a23" alt="Manali Cottage">
            </div>
            <div class="card-content">
                <div class="location">Riverside Cottage, Manali</div>
                <div class="price">₹4,500 / night</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.5)</div>
                <div class="description">
                    Cozy wooden cottages with a direct view of the Beas River and snow-capped peaks.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1614082242765-7c98ca0f3df3" alt="Goa Villa">
            </div>
            <div class="card-content">
                <div class="location">Heritage Villa, North Goa</div>
                <div class="price">₹6,200 / night</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.9)</div>
                <div class="description">
                    Private pool villa located minutes away from Vagator beach with authentic Indo-Portuguese architecture.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957" alt="Rishikesh Stay">
            </div>
            <div class="card-content">
                <div class="location">Yoga Retreat, Rishikesh</div>
                <div class="price">₹1,800 / night</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.3)</div>
                <div class="description">
                    Peaceful stay overlooking the Ganges, perfect for meditation and spiritual seekers.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1593693397690-362cb9666fc2" alt="Munnar Resort">
            </div>
            <div class="card-content">
                <div class="location">Tea Garden Resort, Munnar</div>
                <div class="price">₹3,500 / night</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.7)</div>
                <div class="description">
                    Luxury rooms nestled right inside tea plantations with misty morning balcony views.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1514222134-b57cbb8ce073" alt="Udaipur Haveli">
            </div>
            <div class="card-content">
                <div class="location">Lake View Haveli, Udaipur</div>
                <div class="price">₹5,000 / night</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.8)</div>
                <div class="description">
                    Traditional Rajasthani haveli offering a stunning sunset view of Lake Pichola.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1582298538104-fe2e74c27f59" alt="Pondicherry Stay">
            </div>
            <div class="card-content">
                <div class="location">French Quarter Studio, Pondicherry</div>
                <div class="price">₹2,900 / night</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.6)</div>
                <div class="description">
                    Charming yellow-walled boutique stay located in the heart of White Town.
                </div>
            </div>
        </div>

    </div>

</div>
