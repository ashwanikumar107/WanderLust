<% layout("/layouts/boilerplate") %>

<style>
    .full-width {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background-color: #fdfaf1; /* Warm, rustic cream background */
        padding: 40px 60px;
    }

    .trending-title {
        text-align: center;
        margin-bottom: 40px;
        font-size: 2.2rem;
        font-weight: bold;
        color: #2e7d32; /* Deep harvest green */
    }

    .trending-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    @media (max-width: 992px) {
        .trending-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .trending-container {
            grid-template-columns: 1fr;
        }
        .full-width {
            padding: 20px;
        }
    }

    .trending-card {
        background: white;
        border-radius: 12px;
        overflow: hidden; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        border: 1px solid #e0e0e0;
    }

    .trending-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 25px rgba(46, 125, 50, 0.15);
    }

    .card-img-container {
        width: 100%;
        height: 250px;
        overflow: hidden; 
    }

    .trending-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease; 
    }

    .trending-card:hover img {
        transform: scale(1.1); 
    }

    .card-content {
        padding: 18px;
        flex-grow: 1;
    }

    .location {
        font-size: 18px;
        font-weight: bold;
        color: #1b5e20;
    }

    .price {
        color: #4caf50;
        font-weight: bold;
        margin-top: 6px;
        font-size: 0.9rem;
    }

    .rating {
        color: #ffa000;
        margin-top: 6px;
    }

    .description {
        font-size: 14px;
        color: #5d4037;
        margin-top: 8px;
        line-height: 1.5;
    }
</style>

<div class="full-width">

    <h1 class="trending-title">
        <i class="fa-solid fa-wheat-awn"></i> Authentic Farm Experiences in India
    </h1>

    <div class="trending-container">

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1500382017468-9049fed747ef" alt="Punjab Farm">
            </div>
            <div class="card-content">
                <div class="location">Mustard Fields, Amritsar</div>
                <div class="price">Highlight: Traditional Chulha Food</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.8)</div>
                <div class="description">
                    Experience the heart of Punjab with tractor rides through golden mustard fields and authentic Makki di Roti and Sarson da Saag.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1590447158019-883d8d5f8bc7" alt="Kerala Plantation">
            </div>
            <div class="card-content">
                <div class="location">Spice Gardens, Thekkady</div>
                <div class="price">Highlight: Cardamom & Pepper Tours</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.9)</div>
                <div class="description">
                    Walk through dense, aromatic plantations of black pepper, vanilla, and cinnamon in the misty hills of the Western Ghats.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1559056199-641a0ac8b55e" alt="Coorg Farm">
            </div>
            <div class="card-content">
                <div class="location">Coffee Estates, Coorg</div>
                <div class="price">Highlight: Bean-to-Cup Experience</div>
                <div class="rating">⭐⭐⭐⭐⭐ (5.0)</div>
                <div class="description">
                    Live among Arabica and Robusta plants. Learn the art of coffee picking and processing in India's famous "Coffee Cup."
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1523348837708-15d4a09cfac2" alt="Sikkim Farm">
            </div>
            <div class="card-content">
                <div class="location">Organic Terraces, Gangtok</div>
                <div class="price">Highlight: 100% Organic Farming</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.7)</div>
                <div class="description">
                    Visit the first organic state of India. Explore stepped terrace farming and taste the freshest mountain-grown vegetables.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://imgs.search.brave.com/wDNmF0ntPff6Lhe1xhxtjpAzBneBoQsvdHZ83qJ3ep4/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly90aHVt/YnMuZHJlYW1zdGlt/ZS5jb20vYi9kcmFh/LXZhbGxleS1vYXNp/cy1wYWxtLXRyZWVz/LTMzMjc0MTg2Lmpw/Zw" alt="Rajasthan Farm">
            </div>
            <div class="card-content">
                <div class="location">Desert Oasis Farm, Pali</div>
                <div class="price">Highlight: Millet & Henna Cultivation</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.6)</div>
                <div class="description">
                    Discover how life thrives in the arid desert. Learn about Bajra (millet) cultivation and the famous Sojat Henna farms.
                </div>
            </div>
        </div>

    </div>

</div>