<% layout("/layouts/boilerplate") %>

<style>
    .full-width {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background-color: #f0f8ff; /* Alice Blue - icy feel */
        padding: 40px 60px;
    }

    .trending-title {
        text-align: center;
        margin-bottom: 40px;
        font-size: 2.2rem;
        font-weight: bold;
        color: #01579b; /* Deep Arctic Blue */
    }

    .trending-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    @media (max-width: 992px) {
        .trending-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .trending-container {
            grid-template-columns: 1fr;
        }
        .full-width {
            padding: 20px;
        }
    }

    .trending-card {
        background: white;
        border-radius: 12px;
        overflow: hidden; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        border-bottom: 4px solid #81d4fa;
    }

    .trending-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 25px rgba(1, 87, 155, 0.2);
    }

    .card-img-container {
        width: 100%;
        height: 250px;
        overflow: hidden; 
    }

    .trending-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease; 
    }

    .trending-card:hover img {
        transform: scale(1.1); 
    }

    .card-content {
        padding: 18px;
        flex-grow: 1;
    }

    .location {
        font-size: 18px;
        font-weight: bold;
        color: #0277bd;
    }

    .price {
        color: #00bcd4;
        font-weight: bold;
        margin-top: 6px;
        font-size: 0.9rem;
    }

    .rating {
        color: #ffa000;
        margin-top: 6px;
    }

    .description {
        font-size: 14px;
        color: #546e7a;
        margin-top: 8px;
        line-height: 1.5;
    }
</style>

<div class="full-width">

    <h1 class="trending-title">
        <i class="fa-solid fa-snowflake"></i> India's Arctic: The Frozen Frontiers
    </h1>

    <div class="trending-container">

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://imgs.search.brave.com/zSUOzIX8aR_Wm8dXW43QH2tytBPTlxZKv0nhjW9Jo98/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9pbWct/Y2RuLnB1YmxpdmUu/b25saW5lL2ZpbHRl/cnM6Zm9ybWF0KHdl/YnApL2ZpbHRlcnM6/Zm9ybWF0KHdlYnAp/L2VuZ2xpc2gtYmV0/dGVyaW5kaWEvbWVk/aWEvbWVkaWFfZmls/ZXMvMjAyNS8xMS8x/OS9kcmFzLWxhZGFr/aC0yMDI1LTExLTE5/LTEzLTM1LTQ1LnBu/Zw" alt="Dras Ladakh">
            </div>
            <div class="card-content">
                <div class="location">Dras, Ladakh</div>
                <div class="price">Temp: Drops to -45°C</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.9)</div>
                <div class="description">
                    Known as the 'Gateway to Ladakh' and the second coldest inhabited place on Earth. It offers a true polar-like survival experience.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://imgs.search.brave.com/4sgt9C2wbL_umVXlQNt2sUjBroUzjdWdJ-gqt_iY5fM/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9zdGF0/aWMyLnRyaXBvdG8u/Y29tL21lZGlhL2Zp/bHRlci9ubC9pbWcv/MzkwMzEwL1RyaXBE/b2N1bWVudC8xNTkw/MjMzMDgyX2ltZ18y/MDY2LmpwZy53ZWJw" alt="Sikkim Frozen Lake">
            </div>
            <div class="card-content">
                <div class="location">Gurudongmar Lake, Sikkim</div>
                <div class="price">Altitude: 17,800 Feet</div>
                <div class="rating">⭐⭐⭐⭐⭐ (5.0)</div>
                <div class="description">
                    One of the highest lakes in the world. Even in extreme winter, a part of this sacred lake miraculously never freezes.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://imgs.search.brave.com/crNONSZ43JnTRiZOV_ioYreNSkrO6Ivd8Q95qrFxTyY/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly93aGl0/ZW1hZ2ljYWR2ZW50/dXJlLmNvbS9zaXRl/cy9kZWZhdWx0L2Zp/bGVzL3dwLWNvbnRl/bnQvdXBsb2Fkcy8y/MDE1LzAyL1Bob3Rv/LTJfMS5qcGc" alt="Chadar Trek">
            </div>
            <div class="card-content">
                <div class="location">Chadar Trek, Zanskar</div>
                <div class="price">Experience: Walking on Ice</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.8)</div>
                <div class="description">
                    The ultimate Arctic adventure in India. In winter, the Zanskar River turns into a thick sheet of ice used as a highway by locals.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b" alt="Siachen Glacier">
            </div>
            <div class="card-content">
                <div class="location">Siachen Base Camp, Ladakh</div>
                <div class="price">Highlight: World's Highest Battlefield</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.9)</div>
                <div class="description">
                    The largest glacier in the Karakoram range. It is a vast expanse of snow and ice, recently opened for specialized tourism.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://imgs.search.brave.com/RGjEFQOz5A2Q2avDQjr0oyI-pIPgDYbCECDM86Ye-Sw/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9zN2Fw/MS5zY2VuZTcuY29t/L2lzL2ltYWdlL2lu/Y3JlZGlibGVpbmRp/YS9yb2h0YW5nLXBh/c3MtbWFuYWxpLWhp/bWFjaGFsLXByYWRl/c2gtMS1hdHRyLWhl/cm8_cWx0PTgyJnRz/PTE3MjY3MzA3MDE1/NDU" alt="Frozen Pass">
            </div>
            <div class="card-content">
                <div class="location">Rohtang Pass, Himachal</div>
                <div class="price">Highlight: 20ft Snow Walls</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.7)</div>
                <div class="description">
                    During peak winter, this pass is buried under massive snowdrifts, creating a desolate, beautiful Arctic-like tundra.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://imgs.search.brave.com/4akIoOsZMGQa16bbFoTudJ5qETfjHLRn0Rl-H_h8SDo/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly90aHJp/bGxpbmd0cmF2ZWwu/aW4vd3AtY29udGVu/dC91cGxvYWRzLzIw/MjUvMTAvU2VsYS1Q/YXNzLWFydW5hY2hh/bC1QcmFkZXNoLmpw/Zw" alt="Tawang Frozen Lake">
            </div>
            <div class="card-content">
                <div class="location">Sela Pass, Arunachal Pradesh</div>
                <div class="price">Feature: Paradise Lake (Frozen)</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.6)</div>
                <div class="description">
                    A high-altitude mountain pass where the Sela Lake remains completely frozen for most of the winter months.
                </div>
            </div>
        </div>

    </div>

</div>