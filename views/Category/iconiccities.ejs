<% layout("/layouts/boilerplate") %>

<style>
    /* Full-width section styling */
    .iconic-section {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background-color: #f1f3f5;
        padding: 60px 20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Modern Title Styling */
    .section-title {
        text-align: center;
        margin-bottom: 50px;
        font-size: 2.5rem;
        font-weight: 800;
        color: #2d3436;
        letter-spacing: -1px;
    }

    .section-title i {
        color: #0984e3; 
        margin-right: 12px;
    }

    /* Responsive Grid */
    .iconic-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Card Styling */
    .iconic-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        border: 1px solid rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
    }

    /* Card Lift on Hover */
    .iconic-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    }

    /* Image Wrapper for the Zoom Effect */
    .img-frame {
        width: 100%;
        height: 260px;
        overflow: hidden;
        background-color: #e9ecef; /* Fallback color while loading */
    }

    .iconic-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease, filter 0.6s ease;
    }

    /* Image Hover Effect: Zoom + Brightness */
    .iconic-card:hover img {
        transform: scale(1.1);
        filter: brightness(1.1);
    }

    /* Content Styling */
    .card-body {
        padding: 24px;
        flex-grow: 1;
    }

    .city-name {
        font-size: 22px;
        font-weight: 800;
        color: #2d3436;
        margin-bottom: 5px;
    }

    .state-tag {
        color: #0984e3;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        display: block;
    }

    .highlights {
        color: #fd9644; 
        margin-bottom: 12px;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .city-info {
        font-size: 14px;
        color: #636e72;
        line-height: 1.6;
    }

    /* Mobile adjustments */
    @media (max-width: 768px) {
        .section-title {
            font-size: 1.8rem;
        }
        .iconic-section {
            padding: 40px 15px;
        }
    }
</style>

<div class="iconic-section">
    <h1 class="section-title">
        <i class="fa-solid fa-earth-asia"></i> Iconic Cities of India
    </h1>

    <div class="iconic-container">

        <div class="iconic-card">
            <div class="img-frame">
                <img src="https://images.unsplash.com/photo-1603262110263-fb0112e7cc33?auto=format&fit=crop&w=800&q=80" alt="Hawa Mahal, Jaipur">
            </div>
            <div class="card-body">
                <span class="state-tag">Rajasthan</span>
                <div class="city-name">Jaipur</div>
                <div class="highlights"><i class="fa-solid fa-fort-awesome"></i> Hawa Mahal • Amer Fort</div>
                <div class="city-info">
                    Known as the Pink City, Jaipur is a vibrant showcase of royal heritage, featuring stunning terracotta-colored palaces and intricate astronomical observatories.
                </div>
            </div>
        </div>

        <div class="iconic-card">
            <div class="img-frame">
                <img src="https://imgs.search.brave.com/HEKH4-0aGbK5ypieveV1yMMuLBvHoLc9KeUHpOPZJZM/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9zdGF0/aWMud2l4c3RhdGlj/LmNvbS9tZWRpYS80/ZDMyZjNfZWZkMTVl/ZTM1ODJmNGNhMWI3/MDk4YWE4ZGI0MWI1/YzB-bXYyLmpwZy92/MS9maWxsL3dfNzcx/LGhfNDM0LGFsX2Ms/cV84MCx1c21fMC42/Nl8xLjAwXzAuMDEs/ZW5jX2F2aWYscXVh/bGl0eV9hdXRvLzRk/MzJmM19lZmQxNWVl/MzU4MmY0Y2ExYjcw/OThhYThkYjQxYjVj/MH5tdjIuanBn" alt="Ghats of Varanasi">
            </div>
            <div class="card-body">
                <span class="state-tag">Uttar Pradesh</span>
                <div class="city-name">Varanasi</div>
                <div class="highlights"><i class="fa-solid fa-om"></i> Ganga Aarti • Holy Ghats</div>
                <div class="city-info">
                    One of the world's oldest continually inhabited cities, Varanasi is the spiritual heart of India, famous for its sacred river rituals.
                </div>
            </div>
        </div>

        <div class="iconic-card">
            <div class="img-frame">
                <img src="https://images.unsplash.com/photo-1566552881560-0be862a7c445?auto=format&fit=crop&w=800&q=80" alt="Mumbai Cityscape">
            </div>
            <div class="card-body">
                <span class="state-tag">Maharashtra</span>
                <div class="city-name">Mumbai</div>
                <div class="highlights"><i class="fa-solid fa-clapperboard"></i> Gateway of India • Marine Drive</div>
                <div class="city-info">
                    The city that never sleeps. Mumbai is a high-energy melting pot of Bollywood glamour, colonial history, and bustling street life.
                </div>
            </div>
        </div>

        <div class="iconic-card">
            <div class="img-frame">
                <img src="https://images.unsplash.com/photo-1514222134-b57cbb8ce073?auto=format&fit=crop&w=800&q=80" alt="Golden Temple, Amritsar">
            </div>
            <div class="card-body">
                <span class="state-tag">Punjab</span>
                <div class="city-name">Amritsar</div>
                <div class="highlights"><i class="fa-solid fa-temple"></i> Golden Temple • Wagah Border</div>
                <div class="city-info">
                    Known for the stunning Golden Temple, Amritsar offers deep spiritual vibes and the most legendary culinary experiences in North India.
                </div>
            </div>
        </div>

        <div class="iconic-card">
            <div class="img-frame">
                <img src="https://imgs.search.brave.com/tbO0oTCuT_xFbjihZFJoCY6Gtq7Yevi_KAjOXzSS6N4/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9tZWRp/YS5nZXR0eWltYWdl/cy5jb20vaWQvNTE2/MDAyODIzL3Bob3Rv/L2hhbXBpLWF0LXN1/bnNldC5qcGc_cz02/MTJ4NjEyJnc9MCZr/PTIwJmM9YnJsdjFo/SE1ZRFd2YVN2OWgx/SHFfNm1iQ3ZjcEU5/eUhpM29ocFZtZGVF/WT0" alt="Hampi Ruins">
            </div>
            <div class="card-body">
                <span class="state-tag">Karnataka</span>
                <div class="city-name">Hampi</div>
                <div class="highlights"><i class="fa-solid fa-archway"></i> Ancient Ruins • Stone Chariot</div>
                <div class="city-info">
                    A UNESCO World Heritage site, Hampi's boulder-strewn landscape and ruins of the Vijayanagara Empire feel like a journey back in time.
                </div>
            </div>
        </div>

    </div>
</div>