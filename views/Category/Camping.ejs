<% layout("/layouts/boilerplate") %>

<style>
    .full-width {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background-color: #f0f4ed; /* Earthy, nature-inspired background */
        padding: 40px 60px;
    }

    .trending-title {
        text-align: center;
        margin-bottom: 40px;
        font-size: 2.2rem;
        font-weight: bold;
        color: #2d4739;
    }

    .trending-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    @media (max-width: 992px) {
        .trending-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .trending-container {
            grid-template-columns: 1fr;
        }
        .full-width {
            padding: 20px;
        }
    }

    .trending-card {
        background: white;
        border-radius: 12px;
        overflow: hidden; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .trending-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 25px rgba(45, 71, 57, 0.2);
    }

    .card-img-container {
        width: 100%;
        height: 250px;
        overflow: hidden; 
    }

    .trending-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease; 
    }

    .trending-card:hover img {
        transform: scale(1.1); 
    }

    .card-content {
        padding: 18px;
        flex-grow: 1;
    }

    .location {
        font-size: 18px;
        font-weight: bold;
        color: #1b2e24;
    }

    .price {
        color: #689f38;
        font-weight: bold;
        margin-top: 6px;
        font-size: 0.9rem;
    }

    .rating {
        color: #fbc02d;
        margin-top: 6px;
    }

    .description {
        font-size: 14px;
        color: #4a4a4a;
        margin-top: 8px;
        line-height: 1.5;
    }
</style>

<div class="full-width">

    <h1 class="trending-title">
        <i class="fa-solid fa-tent"></i> Iconic Camping Sites in India
    </h1>

    <div class="trending-container">

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4" alt="Ladakh Camping">
            </div>
            <div class="card-content">
                <div class="location">Lakeside Tents, Pangong Tso</div>
                <div class="price">Experience: High Altitude Stargazing</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.9)</div>
                <div class="description">
                    Camp under the clearest night skies in India, right beside the sapphire blue waters of the world's highest saltwater lake.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1478131143081-80f7f84ca84d" alt="Desert Camping">
            </div>
            <div class="card-content">
                <div class="location">Sam Sand Dunes, Jaisalmer</div>
                <div class="price">Experience: Luxury Glamping & Folk Music</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.7)</div>
                <div class="description">
                    Traditional Swiss tents in the heart of the Thar Desert, featuring camel safaris and Rajasthani cultural performances by the bonfire.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7" alt="River Camping">
            </div>
            <div class="card-content">
                <div class="location">Ganges Riverbed, Rishikesh</div>
                <div class="price">Experience: Adventure & Rafting</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.6)</div>
                <div class="description">
                    Beachside camping along the silver sands of the Ganga, perfect for those seeking white-water rafting and yoga retreats.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1533632359083-0185df1be85d" alt="Rann Camping">
            </div>
            <div class="card-content">
                <div class="location">Tent City, Dhordo (Kutch)</div>
                <div class="price">Experience: The White Desert Moon</div>
                <div class="rating">⭐⭐⭐⭐⭐ (4.8)</div>
                <div class="description">
                    A massive luxury tent city set on the salt marshes of Kutch. It is best experienced during the Rann Utsav under a full moon.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1496080174650-637e3f22fa03" alt="Spiti Camping">
            </div>
            <div class="card-content">
                <div class="location">Chandratal Lake, Spiti</div>
                <div class="price">Experience: Off-grid Expedition</div>
                <div class="rating">⭐⭐⭐⭐⭐ (5.0)</div>
                <div class="description">
                    Camping at the 'Moon Lake' is for true adventurers. Remote, rugged, and surrounded by 360-degree snow-capped peaks.
                </div>
            </div>
        </div>

        <div class="trending-card">
            <div class="card-img-container">
                <img src="https://images.unsplash.com/photo-1470240731273-7821a6eeb6bd" alt="Forest Camping">
            </div>
            <div class="card-content">
                <div class="location">Rainforest Canopy, Wayanad</div>
                <div class="price">Experience: Wildlife & Coffee Estates</div>
                <div class="rating">⭐⭐⭐⭐☆ (4.5)</div>
                <div class="description">
                    Deep forest camping in the Western Ghats, where you wake up to the sounds of tropical birds and the scent of fresh coffee.
                </div>
            </div>
        </div>

    </div>

</div>